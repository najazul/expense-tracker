{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=PLACEHOLDER;..."
  },
  "Jwt": {
    "Issuer": "ExpenseTracker.API",
    "Audience": "expense-tracker-web",
    "SecretKey": "enter_jwt_key",
    "ExpiryDays": 7
  },
  "GoogleAuth": {
    "ClientId": "YOUR-GOOGLE-CLIENT-ID.apps.googleusercontent.com"
  },
  "CloudflareR2": {
    "AccessKey": "YOUR-R2-ACCESS-KEY",
    "SecretKey": "YOUR-R2-SECRET-KEY",
    "ServiceUrl": "https://<ACCOUNT_ID>.r2.cloudflarestorage.com",
    "BucketName": "expense-tracker-receipts",
    "PublicDomain": "https://pub-xxxxxx.r2.dev"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  }
}